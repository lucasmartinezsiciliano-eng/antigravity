# StyleScan — Environment variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git

# App
SECRET_KEY=generate-a-random-64-char-string-here
DEBUG=true

# Database (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./stylescan.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stylescan

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASE_COUPON_ID=  # Leave empty first time — will be created automatically

# Photo config
PHOTO_TEMP_DIR=/tmp/stylescan
MAX_PHOTO_SIZE_MB=10
