# ── Webhook security ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_API_KEY=replace-with-random-hex

# ── IBKR connection ───────────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=4002          # 4002 = IB Gateway paper | 4001 = live
IBKR_USER=your_ibkr_username
IBKR_PASS=your_ibkr_password
TRADING_MODE=paper      # paper | live

# ── Risk management ───────────────────────────────────────────────────────────
ACCOUNT_SIZE=50000       # fallback if IBKR query fails
MAX_RISK_PCT=0.01        # 1% per trade (TJR Day-13)
MAX_TRADES_PER_SESSION=2 # max 2 trades/day (TJR + Fede)
MAX_DAILY_LOSS_PCT=0.03  # 3% daily stop (adjust for Apex: 5%)
MAX_CONSECUTIVE_LOSSES=3 # stop after 3 consecutive losses

# ── Stop loss / Take profit ───────────────────────────────────────────────────
STOP_TICKS=10            # for futures (NQ/ES) — ticks below IFVG
STOP_PIPS=15             # for forex (EURUSD/GBPUSD)
STOP_PCT=0.5             # for stocks — % below entry
MIN_RR=2.0               # minimum Risk:Reward ratio

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Telegram (optional but strongly recommended) ──────────────────────────────
# Get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Log file ──────────────────────────────────────────────────────────────────
LOG_FILE=trades.jsonl
