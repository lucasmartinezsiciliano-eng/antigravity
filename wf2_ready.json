    {
      "id": "wf2-019",
      "name": "Send DM Despedida Knockout",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2440, 680],
      "parameters": {
        "method": "POST",
        "url": "https://graph.facebook.com/v18.0/YOUR_IG_PAGE_ID/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "facebookGraphApi",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "recipient": { "id": "={{ $json.ig_user_id }}" },
          "message": {
